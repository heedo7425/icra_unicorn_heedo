<?xml version="1.0"?>
<launch>
    <arg name="yaml_dir" default="$(find stack_master)/maps/$(optenv MAP_NAME eng_0404_v2)" />

    <!-- launch friction sector slicer -->
    <node pkg="friction_sector_tuner" type="friction_sector_slicing.py" name="friction_sector_node" output="screen">
        <param name="save_dir" value="$(arg yaml_dir)"/>
    </node>
</launch>
