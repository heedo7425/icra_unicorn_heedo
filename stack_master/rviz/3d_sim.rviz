        - /Status1
        - /LivoxPointCloud1
        - /GazeboStaticObs1
        - /GazeboStaticObs1/Status1
      Splitter Ratio: 0.5029411911964417
    Tree Height: 814
  - Class: rviz/Views
    Expanded:
      - /Current View1
    Name: Views
    Splitter Ratio: 0.5
Preferences:
