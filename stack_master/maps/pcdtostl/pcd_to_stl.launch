<?xml version="1.0"?>
<!-- Convert a .pcd point cloud into a .stl mesh for Isaac Sim track ingestion.

     Example:
       roslaunch stack_master pcd_to_stl.launch \
           pcd:=$(rospack find stack_master)/maps/kd_0420_v1/kd_0420_v1.pcd \
           stl:=$(rospack find stack_master)/maps/kd_0420_v1/kd_0420_v1.stl

     Typical workflow: SLAM (GLIM/GLIL) produces a .pcd → run this launch →
     copy output .stl (or convert .stl→.usd offline) into
     /workspace/usd/ on the issac_icra container, then reference it in
     run_mpc_sim.py via --track.
-->
<launch>
  <arg name="pcd"              />                            <!-- input .pcd (required) -->
  <arg name="stl"              />                            <!-- output .stl (required) -->
  <arg name="method"           default="poisson"/>           <!-- poisson | ball_pivot -->
  <arg name="voxel"            default="0.05"/>              <!-- [m] down-sample size, 0 = off -->
  <arg name="normal_radius"    default="0.15"/>              <!-- [m] -->
  <arg name="poisson_depth"    default="9"/>
  <arg name="density_quantile" default="0.02"/>
  <arg name="ball_radii"       default="0.1,0.2,0.4"/>

  <node pkg="stack_master" type="pcd_to_stl.py" name="pcd_to_stl"
        output="screen" required="true"
        args="--pcd $(arg pcd)
              --stl $(arg stl)
              --method $(arg method)
              --voxel $(arg voxel)
              --normal-radius $(arg normal_radius)
              --poisson-depth $(arg poisson_depth)
              --density-quantile $(arg density_quantile)
              --ball-radii $(arg ball_radii)"/>
</launch>
