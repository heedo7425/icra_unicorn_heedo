<launch>
  <!-- ── Arguments ─────────────────────────────────────────────────────────── -->
  <arg name="map"              default="gazebo_wall_2" />
  <arg name="vehicle"          default="rc_car_10th" />
  <arg name="gg_mode"          default="diamond" />
  <arg name="safety_distance"  default="0.25" />
  <arg name="bin_size"         default="0.05" />
  <arg name="smooth_step"      default="0.05" />
  <arg name="opt_step"         default="0.2" />
  <arg name="output"           default="global_waypoints" />
  <arg name="raw_csv"          default="auto" />
  <arg name="gen3d_csv"        default="auto" />
  <arg name="smoothed_csv"     default="auto" />
  <arg name="raceline_csv"     default="auto" />
  <arg name="run_gg"           default="false" />

  <!-- ── Step 0: GG diagram generation (optional, one-time per vehicle) ──── -->
  <node if="$(arg run_gg)"
        pkg="global_line_3d" type="gen_gg_diagrams.py" name="gen_gg_diagrams"
        output="screen"
        cwd="$(find global_line_3d)/gg_diagram_generation"
        args="--vehicle_name $(arg vehicle)" />

  <!-- ── Step 1~6: Full pipeline ───────────────────────────────────────────── -->
  <node unless="$(arg run_gg)"
        pkg="global_line_3d" type="run_pipeline.sh" name="run_pipeline"
        output="screen"
        args="--map-dir $(find stack_master)/maps/$(arg map) --track $(arg map) --vehicle $(arg vehicle) --gg-mode $(arg gg_mode) --safety-distance $(arg safety_distance) --bin-size $(arg bin_size) --smooth-step $(arg smooth_step) --opt-step $(arg opt_step) --output $(arg output) --raw-csv $(arg raw_csv) --gen3d-csv $(arg gen3d_csv) --smoothed-csv $(arg smoothed_csv) --raceline-csv $(arg raceline_csv)" />
</launch>
