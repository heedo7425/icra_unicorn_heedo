Panels:
  - Class: rviz/Displays
    Help Height: 0
    Name: Displays
    Property Tree Widget:
      Expanded:
        - /Global Options1
        - /Accumulated Map1
        - /Current Scan1
        - /TSDF PointCloud1
        - /Dynamic Objects1
        - /Dynamic Points (Segmenter)1
      Splitter Ratio: 0.5
