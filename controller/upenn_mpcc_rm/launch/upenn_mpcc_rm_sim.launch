<?xml version="1.0"?>
<!-- upenn_mpcc_rm — kinematic bicycle 변형.

     원본 upenn_mpcc 의 dynamic bicycle + Pacejka 가 sim (linear tire) 와
     mismatch 가 너무 커서 friction circle 작동 안 했음. 이 변형:
       - sim 에서 friction patches/μ ground-truth 끔 (균질 마찰)
       - GP residual learning 끔
       - dynamic bicycle / Pacejka 끔 → kinematic bicycle 사용
     순수하게 "kinematic 모델로 MPCC 가 코너 감속을 cost balance 만으로 해낼
     수 있는지" 테스트.

     Usage:
       CAR_NAME=SIM roslaunch controller upenn_mpcc_rm_sim.launch map:=f
-->
<launch>
  <arg name="racecar_version" default="SIM"/>
  <arg name="map"             default="f"/>
  <arg name="rviz"            default="true"/>
  <arg name="line"            default="raceline"
       doc="raceline | centerline — MPCC 가 추종할 기준선"/>

  <!-- BASE SIM -->
  <include file="$(find stack_master)/launch/base_system.launch">
    <arg name="racecar_version" value="$(arg racecar_version)"/>
    <arg name="map"             value="$(arg map)"/>
    <arg name="sim"             value="true"/>
  </include>

  <!-- IMU relay (호환용 — 실제로는 kinematic 노드에서 omega 안 씀) -->
  <node name="imu_name_relay" pkg="topic_tools" type="relay"
        args="/vesc/sensors/imu/raw /livox/imu"/>

  <!-- Spawn on wpnt[0] + stuck supervisor -->
  <node pkg="controller" type="spawn_on_waypoint.py" name="spawn_on_waypoint" output="screen">
    <param name="~supervise" value="true"/>
    <param name="~stuck_sec" value="1.5"/>
  </node>

  <!-- Load MPCC params (upenn_mpcc namespace 그대로 — 노드가 그 NS 읽음) -->
  <rosparam command="load"
            file="$(find controller)/upenn_mpcc_rm/config/upenn_mpcc_srx1.yaml"
            ns=""/>
  <param name="upenn_mpcc/line_source" value="$(arg line)"/>

  <!-- ✗ μ patch publisher 제거 — sim 마찰을 균질로 둠 -->
  <!-- ✗ μ GT relay 제거 -->
  <!-- ✗ GP trainer / residual publisher 제거 (mu_source: static) -->

  <!-- MPCC CONTROLLER (rm 변형 import 가 들어간 동일 노드 파일) -->
  <node pkg="controller" type="upenn_mpcc_rm_node.py"
        name="upenn_mpcc_controller" output="screen">
    <param name="~drive_topic" value="/upenn_mpc/cmd_raw"/>
  </node>

  <!-- 단순 cmd 통과 (μ scaling 비활성) -->
  <node pkg="topic_tools" type="relay" name="cmd_relay"
        args="/upenn_mpc/cmd_raw /vesc/high_level/ackermann_cmd_mux/input/nav_1"/>

  <!-- ✗ HUD / μ adaptation GUI 제거 -->

  <!-- RViz (원본 conf 재사용 — prediction/reference 토픽 동일) -->
  <node if="$(arg rviz)" pkg="rviz" type="rviz" name="rviz_upenn_mpcc"
        args="-d $(find controller)/upenn_mpcc/rviz/upenn_mpc.rviz"/>
</launch>
