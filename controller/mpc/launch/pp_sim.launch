<?xml version="1.0"?>
<!-- PP closed-loop sim launch (2D) — diagnosis companion to mpc_sim.launch.

  Identical to mpc_sim.launch except replaces my MPC node with the repo's
  existing controller_manager.py (ctrl_algo=PP). Goal: verify that the sim
  itself + spawn + state_machine + planners chain can drive laps when a
  known-working controller (PP) is at the wheel.

  Usage:
    CAR_NAME=SIM roslaunch controller pp_sim.launch map:=f rviz:=true
-->
<launch>
  <arg name="racecar_version" default="SIM"/>
  <arg name="map"             default="f"/>
  <arg name="rviz"            default="false"/>
  <arg name="ctrl_algo"       default="PP"/>
  <arg name="LU_table"        default="SRX1-0427"/>  <!-- SIM_linear LUT has wrong naming; use SRX1 pacejka LUT for sim too -->


  <!-- 1) BASE: 2D sim + frenet + planners (base_system.launch sim 그룹) -->
  <include file="$(find stack_master)/launch/base_system.launch">
    <arg name="racecar_version" value="$(arg racecar_version)"/>
    <arg name="map"             value="$(arg map)"/>
    <arg name="sim"             value="true"/>
  </include>

  <!-- 2) STATE MACHINE PLANNER PARAMS (3d_state_machine needs this NS). -->
  <group ns="dyn_planners_statemachine">
    <include file="$(find stack_master)/launch/planners.launch"><arg name="planners" value="global_tracking"/></include>
    <include file="$(find stack_master)/launch/planners.launch"><arg name="planners" value="recovery_planner"/></include>
    <include file="$(find stack_master)/launch/planners.launch"><arg name="planners" value="start_planner"/></include>
    <include file="$(find stack_master)/launch/planners.launch"><arg name="planners" value="static_avoidance_planner"/></include>
    <include file="$(find stack_master)/launch/planners.launch"><arg name="planners" value="dynamic_avoidance_planner"/></include>
  </group>

  <!-- 3) STATE MACHINE -->
  <node pkg="state_machine" type="dynamic_statemachine_server.py" name="dyn_statemachine" output="screen"/>
  <node pkg="state_machine" type="3d_state_machine_node.py" name="state_machine" output="screen">
    <rosparam file="$(find stack_master)/config/state_machine_params.yaml"/>
  </node>
  <node pkg="state_machine" type="state_indicator_node.py" name="state_indicator" output="screen"/>

  <!-- 3.5) SPAWN ON FIRST WAYPOINT (no supervise — PP should handle driving). -->
  <node pkg="controller" type="spawn_on_waypoint.py" name="spawn_on_waypoint"
        output="screen" required="false"/>

  <!-- 4) CONTROLLER (existing PP stack via controller_manager). -->
  <rosparam ns="L1_controller" command="load"
    file="$(find stack_master)/config/$(arg racecar_version)/controller.yaml" />
  <node pkg="controller" name="dyn_controller" type="l1_params_server.py" output="screen" />
  <node pkg="controller" name="controller_manager" type="controller_manager.py" output="screen">
    <param name="LU_table"  value="$(arg LU_table)" />
    <param name="ctrl_algo" value="$(arg ctrl_algo)" />
  </node>

  <!-- 5) RViz (optional) -->
  <node if="$(arg rviz)"
        pkg="rviz" type="rviz" name="rviz_pp_sim"
        args="-d $(find f1tenth_simulator)/launch/simulator.rviz"/>
</launch>
