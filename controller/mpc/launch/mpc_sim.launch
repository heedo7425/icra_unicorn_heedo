<?xml version="1.0"?>
<!-- MPC closed-loop sim launch (2D) with full obstacle / state-machine / planner stack.

  구성:
    1) base_system.launch sim:=true        — f1tenth_simulator + frenet + sector servers
    2) dyn_planners_statemachine 그룹      — 3d_state_machine_node 용 planner param 서버
    3) state_machine + planners (headtohead.launch 의 controller 제외 전체)
    4) obstacle_publisher.launch           — sim 용 dummy obstacle (/tracking/obstacles)
    5) spawn_on_waypoint                   — 초기 위치 snap
    6) mpc_standalone.launch               — MPC 노드 (nav_1 publisher)

  perception.launch 는 사용하지 않음. sim 에서는 scan 기반 detect 대신
  obstacle_publisher 가 /tracking/obstacles 를 직접 publish (headtohead.launch
  line 14 코멘트: "False to disable the perception module when using the
  dummy obstacle publisher").

  Usage:
    CAR_NAME=SIM roslaunch controller mpc_sim.launch map:=f rviz:=true
-->
<launch>
  <arg name="racecar_version"       default="SIM"/>
  <arg name="map"                   default="f"/>
  <arg name="rviz"                  default="false"/>
  <arg name="dynamic_avoidance_mode" default="SQP"/>

  <!-- 1) BASE: 2D sim + frenet + sector servers (dyn_planners NS 도 여기서 생성) -->
  <include file="$(find stack_master)/launch/base_system.launch">
    <arg name="racecar_version" value="$(arg racecar_version)"/>
    <arg name="map"             value="$(arg map)"/>
    <arg name="sim"             value="true"/>
  </include>

  <!-- 2) STATE MACHINE PLANNER PARAM SERVERS (3d_headtohead 패턴).
       3d_state_machine_node 가 /dyn_planners_statemachine/<planner>/min_horizon
       같은 param 을 읽는다. -->
  <group ns="dyn_planners_statemachine">
    <include file="$(find stack_master)/launch/planners.launch"><arg name="planners" value="global_tracking"/></include>
    <include file="$(find stack_master)/launch/planners.launch"><arg name="planners" value="recovery_planner"/></include>
    <include file="$(find stack_master)/launch/planners.launch"><arg name="planners" value="start_planner"/></include>
    <include file="$(find stack_master)/launch/planners.launch"><arg name="planners" value="static_avoidance_planner"/></include>
    <include file="$(find stack_master)/launch/planners.launch"><arg name="planners" value="dynamic_avoidance_planner"/></include>
  </group>

  <!-- 3) STATE MACHINE (3d_headtohead 기준). -->
  <node pkg="state_machine" type="dynamic_statemachine_server.py" name="dyn_statemachine" output="screen"/>
  <node pkg="state_machine" type="3d_state_machine_node.py" name="state_machine" output="screen">
    <rosparam file="$(find stack_master)/config/state_machine_params.yaml"/>
  </node>
  <node pkg="state_machine" type="state_indicator_node.py" name="state_indicator" output="screen"/>

  <!-- 3.1) PLANNERS (headtohead.launch 본체의 planner/GP predictor 블록.
       controller_manager 는 제외 — MPC 가 대체). -->
  <!-- RECOVERY -->
  <node pkg="recovery_spliner" type="dynamic_recovery_spline_server.py" name="dyn_planner_recovery" output="screen"/>
  <node pkg="recovery_spliner" type="recovery_spliner_node.py" name="recovery_planner_spline" output="screen"/>
  <!-- START -->
  <node pkg="spliner" type="start_spline_node_v2.py" name="start_planner" output="screen"/>
  <!-- STATIC AVOIDANCE -->
  <node pkg="spliner" type="dynamic_spline_server.py" name="dynamic_spline_tuner_node" output="screen"/>
  <!-- Reactive static avoidance (NOT smart_static; per-tick avoidance spline). -->
  <node pkg="spliner" type="static_avoidance_node.py" name="planner_spline" output="screen">
    <remap from="/planner/avoidance/otwpnts" to="/planner/avoidance/static_otwpnts"/>
  </node>
  <!-- DYNAMIC AVOIDANCE (SQP default) -->
  <group if="$(eval dynamic_avoidance_mode == 'SQP')">
    <node pkg="sqp_planner" type="dynamic_sqp_server.py" name="dynamic_sqp_tuner_node" output="screen"/>
    <node pkg="sqp_planner" type="sqp_avoidance_node.py" name="planner_sqp"          output="screen"/>
    <node pkg="sqp_planner" type="update_waypoints.py"   name="waypoint_updater"     output="screen"/>
  </group>
  <!-- GP OPPONENT PREDICTOR -->
  <node pkg="gp_traj_predictor" type="dynamic_prediction_server.py" name="dynamic_prediction_tuner_node" output="screen"/>
  <node pkg="gp_traj_predictor" type="opp_prediction.py"            name="opponent_propagation_predictor" output="screen">
    <param name="use_vd_prediction"    value="False"/>
    <param name="obstacle_half_width"  value="0.3"/>
  </node>
  <node pkg="gp_traj_predictor" type="opponent_trajectory.py"         name="OpponentHalflap" output="screen"/>
  <node pkg="gp_traj_predictor" type="gaussian_process_opp_traj.py"   name="GP_trajectory"   output="screen" launch-prefix="taskset -c 1"/>
  <node pkg="gp_traj_predictor" type="predictor_opponent_trajectory.py" name="Predictor_Opp" output="screen"/>

  <!-- 4) PERCEPTION — sim f1tenth_simulator publishes /scan; abp_detection
       reads scan and publishes /tracking/obstacles. state_machine 이 이걸
       받아서 OVERTAKE 시 local_wpnts 를 회피 경로로 시프트. -->
  <include file="$(find stack_master)/launch/perception.launch"/>

  <!-- 5) SPAWN ON FIRST WAYPOINT -->
  <node pkg="controller" type="spawn_on_waypoint.py" name="spawn_on_waypoint" output="screen" required="false">
    <param name="~supervise" value="true"/>
    <param name="~stuck_sec" value="1.5"/>
  </node>

  <!-- 6) MPC -->
  <include file="$(find controller)/mpc/launch/mpc_standalone.launch">
    <arg name="test_mode" value="false"/>
  </include>

  <!-- 7) RViz (optional) -->
  <node if="$(arg rviz)"
        pkg="rviz" type="rviz" name="rviz_mpc_sim"
        args="-d $(find controller)/mpc/rviz/mpc_sim.rviz"/>
</launch>
