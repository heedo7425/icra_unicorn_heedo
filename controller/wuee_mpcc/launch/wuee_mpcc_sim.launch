<?xml version="1.0"?>
<!-- wuee_mpcc 2D sim — wueestry/f110-mpcc port.

     True MPCC (state 9D with theta progress, input 3D with derTheta, external
     cost with ql*(s-theta)^2 + qc*n^2 - gamma*derTheta).

     Topics / sim layout 는 upenn_mpc_sim.launch 와 동일:
       base_system (SIM) + spawn_on_waypoint + imu relay + rviz.

     Line source (raceline | centerline):
       - raceline   : /global_waypoints 그대로 구독 (f110-mpcc 원본 동작).
       - centerline : remap /global_waypoints → /centerline_waypoints.
     RViz prediction / reference:
       /mpc_controller/{predicted_position,target_position} 를
       /upenn_mpc/{prediction,reference} 로 remap → 기존 upenn_mpc.rviz
       레이아웃 그대로 재사용.

     Usage:
       CAR_NAME=SIM roslaunch controller wuee_mpcc_sim.launch map:=f
       CAR_NAME=SIM roslaunch controller wuee_mpcc_sim.launch map:=kd_0420_v1 line:=centerline
-->
<launch>
  <arg name="racecar_version" default="SIM"/>
  <arg name="map"             default="f"/>
  <arg name="rviz"            default="true"/>
  <arg name="line"            default="raceline"
       doc="raceline | centerline — MPCC 가 추종할 기준선"/>
  <arg name="config_file"     default="$(find controller)/wuee_mpcc/config/wuee_mpcc_f110sim.yaml"
       doc="wuee_mpcc param config YAML. f110-sim 매칭이 default; SRX1 실차 비교는 wuee_mpcc_srx1.yaml."/>

  <!-- BASE SIM.
       waypoints_topic: mpcc 와 frenet_odom_republisher 가 같은 기준선을 쓰도록
       line=centerline 이면 republisher 도 centerline 으로 switch. 안 맞추면 두
       노드의 frenet 프레임이 달라 prediction / state 에 1m+ offset 발생. -->
  <include file="$(find stack_master)/launch/base_system.launch">
    <arg name="racecar_version"  value="$(arg racecar_version)"/>
    <arg name="map"              value="$(arg map)"/>
    <arg name="sim"              value="true"/>
    <arg name="waypoints_topic"  value="$(eval '/centerline_waypoints' if line == 'centerline' else '/global_waypoints')"/>
  </include>

  <!-- IMU relay (f1tenth_simulator → /livox/imu) -->
  <node name="imu_name_relay" pkg="topic_tools" type="relay"
        args="/vesc/sensors/imu/raw /livox/imu"/>

  <!-- Spawn on wpnt[0] + stuck supervisor.
       centerline 모드일 땐 spawn 도 centerline[0] 으로 맞춰야 mpcc 초기 state
       의 n≈0 이 되어 solver 가 infeasible 에 빠지지 않음. -->
  <node pkg="controller" type="spawn_on_waypoint.py" name="spawn_on_waypoint" output="screen">
    <param name="~supervise" value="true"/>
    <param name="~stuck_sec" value="1.5"/>
    <remap if="$(eval line == 'centerline')"
           from="/global_waypoints" to="/centerline_waypoints"/>
  </node>

  <!-- MPCC SOLVER NODE
       - line=centerline 이면 /global_waypoints 구독을 centerline topic 으로 remap.
       - viz 토픽을 upenn_mpc.rviz 가 보는 이름으로 remap. -->
  <node pkg="controller" type="mpcc_controller.py"
        name="wuee_mpcc_controller" output="screen" required="true">
    <param name="~config_file" value="$(arg config_file)"/>

    <!-- Line source remap: centerline 모드일 때만 global_waypoints 를 centerline 으로. -->
    <remap if="$(eval line == 'centerline')"
           from="/global_waypoints" to="/centerline_waypoints"/>

    <!-- RViz 가 기대하는 이름으로 viz 토픽 재발행. -->
    <remap from="/mpc_controller/predicted_position" to="/upenn_mpc/prediction"/>
    <remap from="/mpc_controller/target_position"   to="/upenn_mpc/reference"/>
  </node>

  <!-- OUTPUT BUFFER NODE — mpcc_controller 의 input_stream/next_input 을 받아
       /vesc/high_level/ackermann_cmd_mux/input/nav_1 로 최종 relay. -->
  <node pkg="controller" type="controller_node.py"
        name="wuee_mpcc_output" output="screen" required="true">
    <param name="~config_file" value="$(arg config_file)"/>
  </node>

  <!-- RViz — upenn_mpc 설정 재사용 (prediction, reference, TF, 맵 등) -->
  <node if="$(arg rviz)" pkg="rviz" type="rviz" name="rviz_wuee_mpcc"
        args="-d $(find controller)/upenn_mpc/rviz/upenn_mpc.rviz"/>
</launch>
