<?xml version="1.0"?>
<!-- upenn_mpc 2D sim — UPenn-style online GP residual MPC.

     Base Pacejka MPC + GP(Δvx, Δvy, Δω) lap-end 학습 + 50Hz runtime residual.
     μ 는 MPC base model 에서 mu_default 고정. mu_applier 는 2D sim 가상 마찰.

     Usage:
       CAR_NAME=SIM roslaunch controller upenn_mpc_sim.launch map:=f mu_source:=gp
       (mu_source: static | ground_truth | gp)
-->
<launch>
  <arg name="racecar_version" default="SIM"/>
  <arg name="map"             default="f"/>
  <arg name="rviz"            default="true"/>
  <arg name="mu_source"       default="gp"
       doc="static | ground_truth | gp"/>
  <arg name="patches_file"    default="$(find controller)/upenn_mpc/config/mu_patches_$(arg map).yaml"/>

  <!-- BASE SIM -->
  <include file="$(find stack_master)/launch/base_system.launch">
    <arg name="racecar_version" value="$(arg racecar_version)"/>
    <arg name="map"             value="$(arg map)"/>
    <arg name="sim"             value="true"/>
  </include>

  <!-- Spawn on wpnt[0] + stuck supervisor -->
  <node pkg="controller" type="spawn_on_waypoint.py" name="spawn_on_waypoint" output="screen">
    <param name="~supervise" value="true"/>
    <param name="~stuck_sec" value="1.5"/>
  </node>

  <!-- Load MPC params (upenn_mpc namespace) and override mu_source -->
  <rosparam command="load"
            file="$(find controller)/upenn_mpc/config/upenn_mpc_srx1.yaml"
            ns=""/>
  <param name="upenn_mpc/mu_source" value="$(arg mu_source)"/>

  <!-- ========== μ PATCH PUBLISHER (sim 가상 마찰 + rviz viz) ========== -->
  <node pkg="controller" type="upenn_mu_patch_publisher.py"
        name="mu_patch_publisher" output="screen">
    <param name="~patches_file" value="$(arg patches_file)"/>
    <param name="~default_mu"   value="0.85"/>
    <param name="~frame_id"     value="map"/>
  </node>

  <!-- ========== μ ESTIMATE (MPC base μ — GP 가 residual 로 마찰 흡수) ==========
       gp 모드에선 mu_estimate 는 mu_default 로 고정. ground_truth 모드는 relay,
       static 은 구독 없이 config 의 mu_default 사용.
  -->
  <node if="$(eval mu_source == 'ground_truth')"
        pkg="topic_tools" type="relay" name="mu_gt_relay"
        args="/mu_ground_truth /upenn_mpc/mu_estimate"/>

  <!-- ========== GP TRAINER + RESIDUAL PUBLISHER (mu_source == gp) ========== -->
  <group if="$(eval mu_source == 'gp')">
    <node pkg="controller" type="upenn_trainer.py"
          name="upenn_trainer" output="screen"/>
    <node pkg="controller" type="upenn_residual_publisher.py"
          name="upenn_residual_publisher" output="screen"/>
  </group>

  <!-- ========== MPC (출력을 raw 토픽으로 → mu_applier 가 scaling) ========== -->
  <node pkg="controller" type="upenn_mpc_node.py" name="upenn_mpc_controller" output="screen">
    <param name="~drive_topic" value="/upenn_mpc/cmd_raw"/>
  </node>

  <!-- ========== μ APPLIER (cmd scaling → sim 실제 효과) ========== -->
  <arg name="apply_mu_to_sim" default="true"
       doc="true 면 ground_truth μ 에 따라 cmd speed/steer scaling"/>
  <node pkg="controller" type="upenn_mu_applier.py" name="mu_applier" output="screen">
    <param name="~reference_mu" value="0.85"/>
    <param name="~ratio_min"    value="0.6"/>
    <param name="~enable"       value="$(arg apply_mu_to_sim)"/>
    <param name="~in_topic"     value="/upenn_mpc/cmd_raw"/>
    <param name="~out_topic"    value="/vesc/high_level/ackermann_cmd_mux/input/nav_1"/>
  </node>

  <!-- ========== HUD (gt vs est μ + residual viz) ========== -->
  <node pkg="controller" type="upenn_mu_hud.py" name="mu_hud" output="screen">
    <param name="~frame_id" value="map"/>
  </node>

  <!-- ========== Adaptation 토글 GUI (tkinter 1-button) ========== -->
  <arg name="toggle_gui" default="true"/>
  <node if="$(arg toggle_gui)" pkg="controller" type="upenn_mu_toggle_gui.py"
        name="mu_toggle_gui" output="screen"/>

  <!-- RViz -->
  <node if="$(arg rviz)" pkg="rviz" type="rviz" name="rviz_upenn_mpc"
        args="-d $(find controller)/upenn_mpc/rviz/upenn_mpc.rviz"/>
</launch>
