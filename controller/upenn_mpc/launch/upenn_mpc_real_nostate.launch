<?xml version="1.0"?>
<!-- upenn_mpc 실차 런치 (nostate: state_machine / planners 우회).

     전제: 3d_base_system.launch 는 별도 터미널에서 먼저 기동되어 있어야 함.
       roslaunch stack_master 3d_base_system.launch map:=<map> racecar_version:=$CAR_NAME SE:=glil_only

     본 런치는 MPC + GP(trainer + residual) + HUD 만 올림.
     /global_waypoints_scaled 직추종 (raceline only, 장애물 회피 없음).
     drive → /vesc/high_level/ackermann_cmd_mux/input/nav_1 직결 (mu_applier 없음).

     동시 실행 금지: 3d_headtohead.launch (controller_manager 가 nav_1 충돌).

     Usage:
       CAR_NAME=SRX1 roslaunch controller upenn_mpc_real_nostate.launch
       (mu_source default=gp. override: static | ground_truth)
-->
<launch>
  <arg name="mu_source"  default="gp"
       doc="static | ground_truth | gp"/>
  <arg name="rviz"       default="false"/>
  <arg name="hud"        default="true"/>
  <arg name="toggle_gui" default="true"/>

  <!-- MPC params (upenn_mpc namespace) -->
  <rosparam command="load"
            file="$(find controller)/upenn_mpc/config/upenn_mpc_srx1.yaml"
            ns=""/>
  <param name="upenn_mpc/mu_source" value="$(arg mu_source)"/>

  <!-- ground_truth relay: 실차에선 /mu_ground_truth 소스가 없으므로 사용 비권장.
       호환 유지용으로만 둠. -->
  <node if="$(eval mu_source == 'ground_truth')"
        pkg="topic_tools" type="relay" name="mu_gt_relay"
        args="/mu_ground_truth /upenn_mpc/mu_estimate"/>

  <!-- GP trainer + residual publisher (gp 모드 전용) -->
  <group if="$(eval mu_source == 'gp')">
    <node pkg="controller" type="upenn_trainer.py"
          name="upenn_trainer" output="screen"/>
    <node pkg="controller" type="upenn_residual_publisher.py"
          name="upenn_residual_publisher" output="screen"/>
  </group>

  <!-- MPC: drive_topic 을 VESC mux 입력에 직결 (applier 생략) -->
  <node pkg="controller" type="upenn_mpc_node.py"
        name="upenn_mpc_controller" output="screen">
    <param name="~drive_topic"
           value="/vesc/high_level/ackermann_cmd_mux/input/nav_1"/>
  </node>

  <!-- HUD (μ 사용치 + residual viz). 실차에선 /mu_ground_truth 가 없으므로
       HUD 는 est 만 표시됨. -->
  <node if="$(arg hud)" pkg="controller" type="upenn_mu_hud.py"
        name="mu_hud" output="screen">
    <param name="~frame_id" value="map"/>
  </node>

  <!-- μ adaptation 토글 GUI (/upenn_mpc/mu_adapt_enable) -->
  <node if="$(arg toggle_gui)" pkg="controller" type="upenn_mu_toggle_gui.py"
        name="mu_toggle_gui" output="screen"/>

  <!-- (옵션) 별도 RViz. 보통 실차는 외부 워크스테이션에서 띄움. -->
  <node if="$(arg rviz)" pkg="rviz" type="rviz" name="rviz_upenn_mpc"
        args="-d $(find controller)/upenn_mpc/rviz/upenn_mpc.rviz"/>
</launch>
