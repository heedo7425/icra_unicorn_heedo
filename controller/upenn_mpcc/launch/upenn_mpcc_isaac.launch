<?xml version="1.0"?>
<!-- upenn_mpc + Isaac Sim integration launch.

     Isaac Sim publishes state via rosbridge_suite (WebSocket). This launch
     brings up the ROS1 side: rosbridge, map, waypoints, MPC, TF, RViz.
     f1tenth_simulator and Gazebo are NOT started here.

     Usage:  CAR_NAME=SIM roslaunch controller upenn_mpc_isaac.launch map:=f
-->
<launch>
  <arg name="racecar_version" default="SIM"/>
  <arg name="map"             default="gazebo_wall_2"/>
  <arg name="rviz"            default="true"/>
  <arg name="rosbridge_port"  default="9090"/>
  <arg name="tire_model"      default="pacejka"/>
  <!-- Set "upenn_mpc" (default) to run the MPC node, "none" to skip it
       (use when testing an external controller like pure-pursuit). -->
  <arg name="controller"      default="upenn_mpcc"/>
  <arg name="line"            default="raceline"
       doc="raceline | centerline — MPC 가 추종할 기준선"/>
  <arg name="wall_viz"        default="true"/>
  <arg name="wall_pcd"        default="$(find stack_master)/maps/$(arg map)/wall.pcd"/>
  <arg name="robot_viz"       default="true"/>
  <!-- wall_viz publishes wall.pcd on /wall_pcd for rviz overlay.
       robot_viz starts joint_state_publisher in the /racecar namespace so
       the URDF's wheel frames get TF (fixes "No transform from front_left_wheel"). -->

  <param name="/racecar_version" value="$(arg racecar_version)"/>
  <param name="/tire_model"      value="$(arg tire_model)"/>
  <param name="sim"              value="true"/>

  <!-- Shared vehicle params (single source of truth with Isaac Sim).
       `vehicle:=srx1` (default) for real hardware / Gazebo, `vehicle:=f1tenth`
       when testing against the Isaac F1TENTH articulation. -->
  <arg name="vehicle" default="srx1"/>
  <rosparam command="load" file="/shared_vehicle/vehicle_$(arg vehicle).yaml"/>

  <!-- rosbridge_server: Isaac Sim connects as a roslibpy client. -->
  <include file="$(find rosbridge_server)/launch/rosbridge_websocket.launch">
    <arg name="port" value="$(arg rosbridge_port)"/>
  </include>

  <!-- Map server (track occupancy grid). -->
  <node pkg="map_server" name="map_server" type="map_server"
        args="$(find stack_master)/maps/$(arg map)/$(arg map).yaml"/>

  <!-- Map-specific sector params (needed by state_machine / planners when
       running alongside headtohead stacks). Files are optional per-map. -->
  <rosparam ns="map_params"            command="load"
            file="$(find stack_master)/maps/$(arg map)/speed_scaling.yaml"/>
  <rosparam ns="ot_map_params"         command="load"
            file="$(find stack_master)/maps/$(arg map)/ot_sectors.yaml"/>
  <rosparam ns="static_obs_map_params" command="load"
            file="$(find stack_master)/maps/$(arg map)/static_obs_sectors.yaml"/>

  <!-- Racecar URDF + robot_state_publisher (for RViz RobotModel display). -->
  <include file="$(find f1tenth_simulator)/launch/racecar_model.launch"/>

  <!-- Model params (tire + geometry for MPC). -->
  <rosparam ns="model_params" command="load"
            file="$(find stack_master)/config/$(arg racecar_version)/$(arg racecar_version)_$(arg tire_model).yaml"/>

  <!-- Global waypoints / raceline publisher. -->
  <node name="global_republisher" pkg="gb_optimizer" type="global_trajectory_publisher.py"
        output="screen">
    <param name="map" value="$(arg map)"/>
  </node>

  <!-- Frenet conversion (needs /car_state/odom from Isaac). -->
  <include file="$(find frenet_odom_republisher)/launch/frenet_odom_republisher.launch"/>

  <!-- Isaac Sim → TF adapter. Publishes map → racecar/base_link so the
       f1tenth RobotModel (which lives under /racecar/robot_description)
       tracks the ego in RViz. -->
  <!-- Isaac Sim broadcasts map -> base_link. The f1tenth racecar URDF root
       link is `base_link` (loaded at /racecar/robot_description, tf_prefix
       commented out in racecar_model.launch), so the RobotModel resolves
       that frame name directly — no "racecar/" prefix. -->
  <node name="isaac_odom_tf" pkg="controller" type="isaac_odom_tf.py"
        output="screen">
    <param name="child_frame" value="base_link"/>
  </node>

  <!-- Lap analyser (for performance metrics in RViz / console). -->
  <node name="lap_analyser" pkg="lap_analyser" type="lap_analyser.py"
        output="screen"/>

  <!-- upenn_mpcc controller (skipped when controller:=none). -->
  <node if="$(eval controller == 'upenn_mpcc')"
        name="upenn_mpcc" pkg="controller" type="upenn_mpcc_node.py"
        output="screen" required="true">
    <rosparam command="load"
              file="$(find controller)/upenn_mpcc/config/upenn_mpcc_srx1.yaml"/>
    <param name="mu_source" value="static"/>
    <param name="gp/enable" value="false"/>
    <param name="line_source" value="$(arg line)"/>
  </node>

  <!-- RViz — upenn_mpcc 디렉토리의 rviz 설정 사용. -->
  <node if="$(arg rviz)" name="rviz" pkg="rviz" type="rviz"
        args="-d $(find controller)/upenn_mpcc/rviz/upenn_mpc.rviz"
        output="screen"/>

  <!-- Wall point-cloud overlay (for rviz visual alignment with the mesh). -->
  <node if="$(arg wall_viz)" name="wall_pcd_publisher"
        pkg="pcl_ros" type="pcd_to_pointcloud"
        args="$(arg wall_pcd) 1.0 cloud_pcd:=/wall_pcd _frame_id:=map"
        output="screen"/>

  <!-- Joint state publisher for URDF's wheel frames (rviz RobotModel TF). -->
  <node if="$(arg robot_viz)" name="racecar_joint_state_publisher"
        ns="racecar"
        pkg="joint_state_publisher" type="joint_state_publisher"
        output="screen"/>
</launch>
