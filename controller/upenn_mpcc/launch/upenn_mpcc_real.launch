<?xml version="1.0"?>
<!-- upenn_mpcc 실차 런치 — 3d_headtohead.launch 대체.

     전제: 3d_base_system.launch 가 별도 터미널에서 먼저 기동되어 있어야 함.
       roslaunch stack_master 3d_base_system.launch map:=<map> racecar_version:=$CAR_NAME SE:=glil_only

     본 런치 = 3d_headtohead 에서 controller_manager (PP/L1) 만 upenn_mpcc 로 교체:
       - upenn_mpcc_node (drive → /vesc/.../nav_1 직결)
       - GP trainer + residual publisher (mu_source==gp)
       - state_machine + dyn_statemachine + planner param 그룹
       - IMU relay (/livox/imu → /imu/data) — upenn_mpcc 가 /imu/data 구독

     동시 실행 금지: 3d_headtohead.launch (nav_1 + state_machine 충돌).

     Usage:
       CAR_NAME=SRX1 roslaunch controller upenn_mpcc_real.launch
       CAR_NAME=SRX1 roslaunch controller upenn_mpcc_real.launch mu_source:=static enable_planners:=true
-->
<launch>
  <arg name="racecar_version"   default="$(env CAR_NAME)"/>
  <arg name="mu_source"         default="gp" doc="static | ground_truth | gp"/>
  <arg name="line"              default="raceline" doc="raceline | centerline"/>
  <arg name="mpc_config"        default="upenn_mpcc_srx1"
       doc="upenn_mpcc/config/[name].yaml basename"/>
  <arg name="hud"               default="true"/>
  <arg name="toggle_gui"        default="false" doc="실차에서는 GUI 비권장"/>
  <arg name="enable_planners"   default="false"/>
  <arg name="enable_prediction" default="false"/>
  <arg name="dynamic_avoidance_mode" default="SQP"/>
  <arg name="use_vd_prediction" default="false"/>

  <param name="measure" value="False"/>

  <!-- ══════════════════ IMU relay (/livox/imu → /imu/data) ══════════════════ -->
  <node name="livox_to_imu_data" pkg="topic_tools" type="relay"
        args="/livox/imu /imu/data"/>

  <!-- ══════════════════ MPCC params ══════════════════ -->
  <rosparam command="load"
            file="$(find controller)/upenn_mpcc/config/$(arg mpc_config).yaml" ns=""/>
  <param name="upenn_mpcc/mu_source"   value="$(arg mu_source)"/>
  <param name="upenn_mpcc/line_source" value="$(arg line)"/>

  <node if="$(eval mu_source == 'ground_truth')"
        pkg="topic_tools" type="relay" name="mu_gt_relay"
        args="/mu_ground_truth /upenn_mpc/mu_estimate"/>

  <group if="$(eval mu_source == 'gp')">
    <node pkg="controller" type="upenn_trainer.py" name="upenn_trainer" output="screen"/>
    <node pkg="controller" type="upenn_residual_publisher.py" name="upenn_residual_publisher" output="screen"/>
  </group>

  <!-- ══════════════════ MPCC node ══════════════════ -->
  <node pkg="controller" type="upenn_mpcc_node.py" name="upenn_mpcc_controller" output="screen">
    <param name="~drive_topic" value="/vesc/high_level/ackermann_cmd_mux/input/nav_1"/>
  </node>

  <node if="$(arg hud)" pkg="controller" type="upenn_mu_hud.py" name="mu_hud" output="screen">
    <param name="~frame_id" value="map"/>
  </node>
  <node if="$(arg toggle_gui)" pkg="controller" type="upenn_mu_toggle_gui.py"
        name="mu_toggle_gui" output="screen"/>

  <!-- ══════════════════ STATE MACHINE (3D) ══════════════════ -->
  <node pkg="state_machine" type="dynamic_statemachine_server.py"
        name="dyn_statemachine" output="screen"/>
  <node pkg="state_machine" type="3d_state_machine_node.py" name="state_machine">
    <rosparam file="$(find stack_master)/config/state_machine_params.yaml"/>
  </node>

  <group ns="dyn_planners_statemachine">
    <include file="$(find stack_master)/launch/planners.launch"><arg name="planners" value="global_tracking"/></include>
    <include file="$(find stack_master)/launch/planners.launch"><arg name="planners" value="recovery_planner"/></include>
    <include file="$(find stack_master)/launch/planners.launch"><arg name="planners" value="start_planner"/></include>
    <include file="$(find stack_master)/launch/planners.launch"><arg name="planners" value="static_avoidance_planner"/></include>
    <include file="$(find stack_master)/launch/planners.launch"><arg name="planners" value="dynamic_avoidance_planner"/></include>
  </group>

  <!-- ══════════════════ 3D PLANNERS (enable_planners:=true) ══════════════════ -->
  <group if="$(arg enable_planners)">
    <group ns="dyn_planner_tuner">
      <node pkg="recovery_spliner" type="dynamic_recovery_spline_server.py" name="recovery" output="screen"/>
      <node pkg="spliner"          type="dynamic_spline_server.py"          name="static_avoidance" output="screen"/>
    </group>
    <node pkg="recovery_spliner" type="3d_recovery_spliner_node.py" name="recovery_planner_spline" output="screen"/>
    <node pkg="spliner"          type="start_spline_node_v2.py"     name="start_planner" output="screen"/>
    <node pkg="spliner"          type="3d_static_avoidance_node.py" name="planner_spline" output="screen">
      <remap from="/planner/avoidance/otwpnts" to="/planner/avoidance/static_otwpnts"/>
    </node>

    <group if="$(eval dynamic_avoidance_mode == 'SQP')">
      <node pkg="sqp_planner" type="dynamic_sqp_server.py"  name="dynamic_sqp_tuner_node" output="screen"/>
      <node pkg="sqp_planner" type="3d_sqp_avoidance_node.py" name="planner_sqp" output="screen"/>
      <node pkg="sqp_planner" type="update_waypoints.py"    name="waypoint_updater" output="screen"/>
    </group>
  </group>

  <!-- ══════════════════ GP PREDICTION (enable_prediction:=true) ══════════════════ -->
  <group if="$(arg enable_prediction)">
    <node pkg="gp_traj_predictor" type="dynamic_prediction_server.py" name="dynamic_prediction_tuner_node" output="screen"/>
    <node pkg="gp_traj_predictor" type="3d_opp_prediction.py" name="opponent_propagation_predictor" output="screen">
      <param name="use_vd_prediction" value="$(arg use_vd_prediction)"/>
      <param name="obstacle_half_width" value="0.3"/>
    </node>
    <node pkg="gp_traj_predictor" type="3d_opponent_trajectory.py" name="OpponentHalflap" output="screen"/>
    <node pkg="gp_traj_predictor" type="gaussian_process_opp_traj.py" name="GP_trajectory" output="screen" launch-prefix="taskset -c 1"/>
    <node pkg="gp_traj_predictor" type="predictor_opponent_trajectory.py" name="Predictor_Opp" output="screen"/>
  </group>
</launch>
