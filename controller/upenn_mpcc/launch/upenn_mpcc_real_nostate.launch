<?xml version="1.0"?>
<!-- upenn_mpcc 실차 런치 (nostate: state_machine / planners 우회).

     전제: 3d_base_system.launch 는 별도 터미널에서 먼저 기동되어 있어야 함.
       roslaunch stack_master 3d_base_system.launch map:=<map> racecar_version:=$CAR_NAME SE:=glil_only

     본 런치는 MPCC + GP(trainer + residual) + HUD 만 올림.
     /global_waypoints_scaled 직추종 (raceline only, 장애물 회피 없음).
     drive → /vesc/high_level/ackermann_cmd_mux/input/nav_1 직결.

     동시 실행 금지: 3d_headtohead.launch (nav_1 충돌).

     Usage:
       CAR_NAME=SRX1 roslaunch controller upenn_mpcc_real_nostate.launch
-->
<launch>
  <arg name="mu_source"  default="gp"
       doc="static | ground_truth | gp"/>
  <arg name="line"       default="raceline"
       doc="raceline | centerline — MPCC 가 추종할 기준선"/>
  <arg name="rviz"       default="false"/>
  <arg name="hud"        default="true"/>
  <arg name="toggle_gui" default="true"/>

  <!-- MPCC params (upenn_mpcc namespace) -->
  <rosparam command="load"
            file="$(find controller)/upenn_mpcc/config/upenn_mpcc_srx1.yaml"
            ns=""/>
  <param name="upenn_mpcc/mu_source" value="$(arg mu_source)"/>
  <param name="upenn_mpcc/line_source" value="$(arg line)"/>

  <!-- ground_truth relay -->
  <node if="$(eval mu_source == 'ground_truth')"
        pkg="topic_tools" type="relay" name="mu_gt_relay"
        args="/mu_ground_truth /upenn_mpc/mu_estimate"/>

  <!-- GP trainer + residual publisher -->
  <group if="$(eval mu_source == 'gp')">
    <node pkg="controller" type="upenn_trainer.py"
          name="upenn_trainer" output="screen"/>
    <node pkg="controller" type="upenn_residual_publisher.py"
          name="upenn_residual_publisher" output="screen"/>
  </group>

  <!-- MPCC: drive_topic 을 VESC mux 에 직결 -->
  <node pkg="controller" type="upenn_mpcc_node.py"
        name="upenn_mpcc_controller" output="screen">
    <param name="~drive_topic"
           value="/vesc/high_level/ackermann_cmd_mux/input/nav_1"/>
  </node>

  <!-- HUD -->
  <node if="$(arg hud)" pkg="controller" type="upenn_mu_hud.py"
        name="mu_hud" output="screen">
    <param name="~frame_id" value="map"/>
  </node>

  <!-- μ adaptation 토글 GUI -->
  <node if="$(arg toggle_gui)" pkg="controller" type="upenn_mu_toggle_gui.py"
        name="mu_toggle_gui" output="screen"/>

  <node if="$(arg rviz)" pkg="rviz" type="rviz" name="rviz_upenn_mpcc"
        args="-d $(find controller)/upenn_mpcc/rviz/upenn_mpc.rviz"/>
</launch>
