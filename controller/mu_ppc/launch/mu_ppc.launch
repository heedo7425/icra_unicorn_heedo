<?xml version="1.0"?>
<!--
  Standalone launch for friction-aware Pure Pursuit (mu_ppc).

  Drop-in replacement for the controller_manager+dyn_controller pair in
  headtohead.launch. This launch DOES NOT start state_machine, planners,
  perception, or friction_sector_tuner — bring those up via base_system /
  3d_base_system separately.

  Required topics (provided by base_system + state_machine):
    /behavior_strategy            (f110_msgs/BehaviorStrategy)
    /car_state/odom               (nav_msgs/Odometry)
    /car_state/pose               (geometry_msgs/PoseStamped)
    /car_state/odom_frenet        (nav_msgs/Odometry)
    /imu/data                     (sensor_msgs/Imu)
    /vesc/odom                    (nav_msgs/Odometry)
  Required params:
    /global_republisher/track_length
    /vesc/wheelbase
    /friction_map_params/...      (optional — if absent, mu prior = 1.0)

  Example usage (assumes 3d_base_system already running):
    roslaunch controller mu_ppc.launch racecar_version:=$CAR_NAME
-->
<launch>
  <arg name="racecar_version" default="$(optenv CAR_NAME UNICORN2)" doc="UNICORNx physical car"/>
  <arg name="config"          default="$(find controller)/mu_ppc/config/mu_ppc.yaml"/>
  <arg name="drive_topic"     default="/vesc/high_level/ackermann_cmd_mux/input/nav_1"/>
  <arg name="rate"            default="50"/>

  <node pkg="controller" type="mu_ppc_node.py" name="mu_ppc" output="screen">
    <rosparam command="load" file="$(arg config)" subst_value="true"/>
    <param name="rate"        value="$(arg rate)"/>
    <param name="drive_topic" value="$(arg drive_topic)"/>
  </node>
</launch>
