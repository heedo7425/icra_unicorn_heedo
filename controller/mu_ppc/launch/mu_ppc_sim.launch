<?xml version="1.0"?>
<!--
  mu_ppc_sim.launch — friction-aware Pure Pursuit on f1tenth_simulator (2D).

  Usage:
    roslaunch controller mu_ppc_sim.launch                       # default map=f
    roslaunch controller mu_ppc_sim.launch map:=kd_0420_v1
    roslaunch controller mu_ppc_sim.launch rviz:=false
    roslaunch controller mu_ppc_sim.launch inject_zone:=true     # auto-inject demo friction zone

  Prereqs satisfied by this launch:
    base_system (sim)            → /map, /global_waypoints, /car_state/*, /vesc/odom, /imu/data
    state_machine_node           → /behavior_strategy (local wpnts inside)
    recovery + start planner     → so state_machine has wpnts to chew on
    mu_ppc_node                  → /mu_ppc/{lookahead, alpha, debug}, drive cmd

  Note: controller_manager is intentionally NOT launched (mu_ppc replaces it).
-->
<launch>
  <arg name="racecar_version" default="SIM"/>
  <arg name="map"             default="f"/>
  <arg name="rviz"            default="true"/>
  <arg name="rate"            default="50"/>
  <arg name="drive_topic"     default="/vesc/high_level/ackermann_cmd_mux/input/nav_1"/>
  <arg name="config"          default="$(find controller)/mu_ppc/config/mu_ppc.yaml"/>
  <arg name="vehicle_yaml"    default="/shared_vehicle/vehicle_srx1.yaml"/>

  <!-- demo friction zone injection (for prior-only testing) -->
  <arg name="inject_zone"     default="false"/>
  <arg name="zone_s_start"    default="5.0"/>
  <arg name="zone_s_end"      default="10.0"/>
  <arg name="zone_friction"   default="0.5"/>

  <!-- vehicle params (wheelbase etc.) -->
  <rosparam command="load" file="$(arg vehicle_yaml)" ns=""/>

  <!-- ============================================================ Base sim -->
  <include file="$(find stack_master)/launch/base_system.launch">
    <arg name="racecar_version" value="$(arg racecar_version)"/>
    <arg name="map"             value="$(arg map)"/>
    <arg name="sim"             value="true"/>
  </include>

  <!-- IMU relay (sim publishes on /vesc/sensors/imu/raw, mu_ppc wants /imu/data) -->
  <node name="imu_relay_to_imu_data" pkg="topic_tools" type="relay"
        args="/vesc/sensors/imu/raw /imu/data"/>

  <!-- spawn on raceline + stuck supervisor (same as mpcc_kine_sim) -->
  <node pkg="controller" type="spawn_on_waypoint.py" name="spawn_on_waypoint" output="screen">
    <param name="~supervise" value="true"/>
    <param name="~stuck_sec" value="1.5"/>
  </node>

  <!-- lap_analyser unblock for sim -->
  <node pkg="rostopic" type="rostopic" name="state_marker_dummy"
        args="pub -l /state_marker visualization_msgs/Marker
              '{header: {frame_id: map},
                pose: {position: {x: 0, y: 0, z: 0}, orientation: {w: 1}}}' "/>
  <node pkg="rostopic" type="rostopic" name="lap_analyser_autostart"
        args="pub -l /lap_analyser/start std_msgs/Empty '{}' " launch-prefix="bash -c 'sleep 3; $0 $@'"/>

  <!-- ====================================================== State machine -->
  <node pkg="state_machine" type="dynamic_statemachine_server.py"
        name="dyn_statemachine" output="screen"/>
  <node pkg="state_machine" type="state_machine_node.py" name="state_machine" output="screen">
    <rosparam file="$(find stack_master)/config/state_machine_params.yaml"/>
  </node>

  <!-- minimal planners so state_machine has waypoints to publish -->
  <node pkg="recovery_spliner" type="dynamic_recovery_spline_server.py"
        name="dyn_planner_recovery" output="screen"/>
  <node pkg="recovery_spliner" type="recovery_spliner_node.py"
        name="recovery_planner_spline" output="screen"/>
  <node pkg="spliner" type="start_spline_node_v2.py"
        name="start_planner" output="screen"/>

  <!-- ============================================================ mu_ppc -->
  <node pkg="controller" type="mu_ppc_node.py" name="mu_ppc" output="screen">
    <rosparam command="load" file="$(arg config)" subst_value="true"/>
    <param name="rate"        value="$(arg rate)"/>
    <param name="drive_topic" value="$(arg drive_topic)"/>
  </node>

  <!-- ============================================ optional friction zone -->
  <group if="$(arg inject_zone)">
    <param name="/friction_map_params/n_sectors" value="1"/>
    <param name="/friction_map_params/global_friction_limit" value="1.0"/>
    <param name="/friction_map_params/Sector0/s_start"  value="$(arg zone_s_start)"/>
    <param name="/friction_map_params/Sector0/s_end"    value="$(arg zone_s_end)"/>
    <param name="/friction_map_params/Sector0/friction" value="$(arg zone_friction)"/>
  </group>

  <!-- ============================================================== RViz -->
  <node if="$(arg rviz)" pkg="rviz" type="rviz" name="rviz_mu_ppc"
        args="-d $(find controller)/mu_ppc/rviz/mu_ppc.rviz"/>
</launch>
