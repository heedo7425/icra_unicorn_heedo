<?xml version="1.0"?>
<!-- 2D sim + 기존 race_stack PPC + mu_ppc_filter (overlay).

     PPC 본체 (controller_manager + combined.Controller PP) 는 손대지 않음.
     출력 토픽만 /mu_ppc/drive_raw 로 redirect → mu_ppc_filter 가 friction
     기반 후처리 (v_circle clamp, max_steer scale) 후 nav_1 으로 republish.

     Usage:
       CAR_NAME=SIM roslaunch controller mu_ppc_sim.launch map:=f
       CAR_NAME=SIM roslaunch controller mu_ppc_sim.launch map:=f sim_mu_patch:=false
-->
<launch>
  <arg name="racecar_version"  default="SIM"/>
  <arg name="map"              default="f"/>
  <arg name="rviz"             default="true"/>
  <arg name="ctrl_algo"        default="PP"/>
  <arg name="LU_table"         default="SRX1-0427"/>
  <arg name="sim_mu_patch"     default="true"
       doc="true 면 sim 의 grip 도 sector-별로 변동 (mu_patch_node + simulator.cpp 패치)."/>

  <!-- 1) base_system (sim) -->
  <include file="$(find stack_master)/launch/base_system.launch">
    <arg name="racecar_version" value="$(arg racecar_version)"/>
    <arg name="map"             value="$(arg map)"/>
    <arg name="sim"             value="true"/>
  </include>

  <!-- f110-simulator pbl_params.yaml 의 drive_topic 과 nav_drive_topic 이 SAME
       (`.../input/nav_1`) 이라서 mux_controller 가 자기 pub 을 자기 sub 로 받아
       100 kHz 무한 feedback loop 형성 (rostopic hz 로 확인). sim 이 토픽 폭주에 묻혀
       cmd 를 거의 못 처리.
       drive_topic (mux→sim 경로) 을 별도 토픽으로 분리해 loop 끊음.
       pbl_sim.launch 가 mux_controller / f1tenth_simulator / behavior_controller 에
       각각 pbl_params.yaml 을 private 로 로드하므로 해당 노드별로 override 한다.
       (param 은 roslaunch 처리 순서상 include 후에 와야 덮어씀.) -->
  <param name="/mux_controller/drive_topic"      value="/sim/drive_to_car"/>
  <param name="/f1tenth_simulator/drive_topic"   value="/sim/drive_to_car"/>
  <param name="/behavior_controller/drive_topic" value="/sim/drive_to_car"/>


  <node name="imu_name_relay" pkg="topic_tools" type="relay"
        args="/vesc/sensors/imu/raw /livox/imu"/>

  <!-- spawn_on_waypoint 의 supervise=true 가 1.5초 stuck 감지 시 /initialpose
       publish 해서 sim state reset → 차가 가속 시작도 못 하고 매 1.5초마다 리셋.
       끄거나 stuck_sec 충분히 크게. 여기선 supervise 비활성화. -->
  <node pkg="controller" type="spawn_on_waypoint.py" name="spawn_on_waypoint" output="screen">
    <param name="~supervise" value="false"/>
  </node>

  <!-- 2) Friction sector plumbing -->
  <node pkg="controller" type="friction_loader.py" name="friction_loader" output="screen">
    <param name="~map" value="$(arg map)"/>
  </node>

  <!-- 3) Sim grip override (옵션) -->
  <node if="$(arg sim_mu_patch)" pkg="controller" type="mu_patch_node.py"
        name="mu_patch" output="screen"/>

  <!-- 4) 기존 PPC — 출력만 /mu_ppc/drive_raw 로 redirect -->
  <rosparam ns="L1_controller" command="load"
            file="$(find stack_master)/config/$(arg racecar_version)/controller.yaml"/>
  <!-- sim 의 compute_accel 은 kp=1.5 P-controller (시정수 0.67초) 라 PPC 의
       AccelLim (v_max_next = v_now + ax*dt) 과 캐스케이드되면 ramp 가 0.15 m/s²
       수준으로 떨어져 raceline 도달까지 30+초. 실차 vesc 는 cmd 에 즉응하므로
       AccelLim 이 의미있지만 sim 에선 핸디캡. 비활성화. -->
  <param name="/L1_controller/accel_limiter_enabled" value="false"/>
  <node pkg="controller" name="dyn_controller" type="l1_params_server.py" output="screen"/>
  <node pkg="controller" name="controller_manager" type="controller_manager.py"
        output="screen" respawn="true" respawn_delay="2">
    <param name="LU_table"  value="$(arg LU_table)"/>
    <param name="ctrl_algo" value="$(arg ctrl_algo)"/>
    <param name="drive_topic" value="/mu_ppc/drive_raw"/>
  </node>

  <!-- state_machine: controller_manager 가 /behavior_strategy 구독 -->
  <node pkg="state_machine" type="dynamic_statemachine_server.py" name="dyn_statemachine" output="screen"/>
  <!-- state_machine 은 /car_state/odom + /global_waypoints_scaled +
       /global_waypoints/overtaking + /car_state/odom_frenet 4개 wait_for_message
       하므로 base_system 노드들 준비 전에 기동되면 죽을 수 있음. respawn 으로 복구. -->
  <node pkg="state_machine" type="state_machine_node.py" name="state_machine"
        output="screen" respawn="true" respawn_delay="2">
    <rosparam command="load" file="$(find stack_master)/config/state_machine_params.yaml"/>
  </node>
  <node pkg="state_machine" type="state_indicator_node.py" name="state_indicator" output="screen"/>

  <!-- 5) mu_ppc_filter — overlay 후 nav_1 으로 publish -->
  <node pkg="controller" type="mu_ppc_filter.py" name="mu_ppc_filter" output="screen">
    <param name="~drive_in"  value="/mu_ppc/drive_raw"/>
    <param name="~drive_out" value="/vesc/high_level/ackermann_cmd_mux/input/nav_1"/>
  </node>

  <!-- 6) RViz -->
  <node if="$(arg rviz)" pkg="rviz" type="rviz" name="rviz_mu_ppc"
        args="-d $(find controller)/mu_ppc/rviz/mu_ppc.rviz" required="false"/>
</launch>
